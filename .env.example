# =============================================================================
# SaaSWPP AI - Configuração de Ambiente
# Domínio: saaswpp.work
# Arquitetura: Motor WhatsApp (16GB) + Cérebro SaaS (8GB)
# =============================================================================

# =============================================================================
# APLICAÇÃO (Servidor 8GB - 192.168.88.252)
# "Cérebro do SaaS" - Painel, pagamentos, banco de dados
# =============================================================================
NODE_ENV=production
APP_URL=https://saaswpp.work
PLATFORM_URL=https://saaswpp.work
PLATFORM_NAME=SaaSWPP
PORT=3001

# =============================================================================
# BANCO DE DADOS (PostgreSQL Local no servidor 8GB)
# =============================================================================
DATABASE_URL="postgresql://saaswpp:SuaSenhaSegura123@localhost:5432/saaswpp"

# =============================================================================
# REDIS (Servidor 16GB - Motor WhatsApp)
# Redis dedicado para filas de mensagens
# =============================================================================
REDIS_URL="redis://:SuaSenhaRedis123@192.168.88.254:6379"

# =============================================================================
# EVOLUTION API (Servidor 16GB - Motor WhatsApp)
# =============================================================================
EVOLUTION_API_URL=http://192.168.88.254:8080
EVOLUTION_API_KEY=sua-chave-evolution-api
EVOLUTION_INSTANCE_NAME=MainInstance

# =============================================================================
# STRIPE (Pagamentos)
# =============================================================================
STRIPE_SECRET_KEY=sk_live_xxx
STRIPE_PUBLISHABLE_KEY=pk_live_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# =============================================================================
# GOOGLE GEMINI (IA)
# =============================================================================
GEMINI_API_KEYS=AIzaSyXXX1,AIzaSyXXX2,AIzaSyXXX3
GEMINI_API_KEY=AIzaSyXXX

# =============================================================================
# GLM-4.7-FLASH (Zhipu AI / ChatGLM) - RECOMENDADO PARA PT-BR
# Obtenha sua chave em: https://open.bigmodel.cn/
# =============================================================================
GLM_API_KEY=your-glm-api-key-here
GLM_MODEL=glm-4.7-flash

# =============================================================================
# OPENAI (Alternativa/Backup)
# =============================================================================
OPENAI_API_KEY=sk-xxx

# =============================================================================
# ANTHROPIC (Alternativa)
# =============================================================================
ANTHROPIC_API_KEY=sk-ant-xxx

# =============================================================================
# DEEPSEEK (Alternativa Econômica)
# =============================================================================
DEEPSEEK_API_KEY=sk-xxx

# =============================================================================
# AUTENTICAÇÃO
# =============================================================================
JWT_SECRET=sua-chave-jwt-super-secreta-minimo-32-caracteres
JWT_EXPIRES_IN=7d

# =============================================================================
# CONFIGURAÇÕES DE TRIAL
# =============================================================================
TRIAL_ENABLED=true
TRIAL_DEFAULT_DAYS=7
TRIAL_TOKEN_LIMIT=50000

# =============================================================================
# CONFIGURAÇÕES DE GRACE PERIOD
# =============================================================================
GRACE_PERIOD_DAYS=7

# =============================================================================
# META WHATSAPP BUSINESS API (Opcional - Alternativa à Evolution)
# =============================================================================
META_APP_ID=
META_APP_SECRET=
META_ACCESS_TOKEN=
META_PHONE_NUMBER_ID=
META_WABA_ID=
META_VERIFY_TOKEN=
